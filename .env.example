PORT=3010
PRICING_API_KEY=defina_um_segredo_longo_compartilhado_com_o_backend

# Opcional: mesmo Redis do stack (recomendado para cache de preços)
REDIS_HOST=redis
REDIS_PORT=6379

# Rate limit (busca por IP)
SEARCH_RATE_LIMIT_WINDOW_MS=60000
SEARCH_RATE_LIMIT_MAX=40

# Rate limit global /v1 (por IP)
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=300

LOG_LEVEL=info
